# ── Stripe Keys ──────────────────────────────────────────────────────────────
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_PUBLIC_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...

# Get from https://dashboard.stripe.com/webhooks  (after creating the endpoint)
# Endpoint URL: https://yourdomain.com/api/webhooks/stripe
STRIPE_WEBHOOK_SECRET=whsec_...

# ── GoCardless (optional – UK BACS Direct Debit alternative) ──────────────────
# Get from https://manage.gocardless.com/developers
GOCARDLESS_ACCESS_TOKEN=

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite path is set in db/init.mjs — no DATABASE_URL needed for SQLite
# If migrating to PostgreSQL, set this:
# DATABASE_URL=postgresql://user:password@localhost:5432/cleartorque

# ── App ───────────────────────────────────────────────────────────────────────
# Base URL used to build Stripe success/cancel redirect URLs
APP_BASE_URL=http://localhost:3000

# ── Security ──────────────────────────────────────────────────────────────────
# REQUIRED in production: long random string for session signing & CSRF tokens
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=replace-with-a-very-long-random-string-at-least-64-chars

# Set to "production" to enable HTTPS-only cookies, HSTS, and secure redirects
NODE_ENV=development

# Restrict all API/CORS calls to your domain (leave blank in development)
# ALLOWED_ORIGIN=https://yourdomain.com

# Comma-separated IPs allowed to reach the admin panel (leave blank to allow all)
# ADMIN_IP_WHITELIST=1.2.3.4,5.6.7.8

# Set to "1" if running behind a trusted reverse proxy (Nginx, Cloudflare, etc.)
# TRUST_PROXY=1
